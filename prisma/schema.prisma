// =============================================================================
// Schema Prisma para o PDS - PostgreSQL (Supabase)
// Documentação Prisma: https://pris.ly/d/supabase
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Usuário da aplicação: vinculado ao auth.users do Supabase via supabaseUserId.
// Um usuário pode ser dono (OWNER) de uma empresa ou motorista (DRIVER).
// -----------------------------------------------------------------------------
model User {
  id              String   @id @default(cuid())
  supabaseUserId  String?  @unique @map("supabase_user_id")
  email           String   @unique
  role            Role     @default(OWNER)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company?  @relation("CompanyOwner")
  expensesCreated Expense[] @relation("ExpenseCreatedBy")

  @@map("usuarios")
}

enum Role {
  OWNER   // Dono da empresa (acessa empresa, veículos, motoristas, viagens)
  DRIVER  // Motorista (acessa apenas suas viagens e acertos)
  ADMIN   // Futuro: administrador com mais permissões

  @@map("role")
}

// -----------------------------------------------------------------------------
// Empresa: dados cadastrais do dono; uma empresa por usuário OWNER.
// -----------------------------------------------------------------------------
model Company {
  id               String   @id @default(cuid())
  name             String
  document         String?  // CPF ou CNPJ
  address          String?
  phone            String?
  email            String?
  defaultCommission Decimal? @db.Decimal(5, 2) // % comissão padrão
  ownerId          String   @unique @map("owner_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  owner   User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  drivers Driver[]
  trips   Trip[]
  expenseCategories ExpenseCategory[]

  @@map("empresas")
}

// -----------------------------------------------------------------------------
// Categorias de despesas: companyId null = categoria do sistema (pré-definida);
// companyId preenchido = categoria customizada da empresa. Nome único por empresa.
// -----------------------------------------------------------------------------
model ExpenseCategory {
  id         String    @id @default(cuid())
  companyId  String?   @map("company_id")
  name       String
  icon       String    @default("receipt")
  color      String    @default("#6b7280")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@unique([companyId, name])
  @@map("categorias_despesas")
}

// -----------------------------------------------------------------------------
// Veículo: placa única por empresa; status para ativo/inativo/manutenção.
// -----------------------------------------------------------------------------
model Vehicle {
  id         String        @id @default(cuid())
  plate      String        // placa (validação BR no app)
  model      String
  brand      String
  year       Int
  nickname   String?
  status     VehicleStatus @default(ACTIVE)
  photoUrl   String?       @map("photo_url") // Supabase Storage
  companyId  String        @map("company_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  drivers    Driver[]      @relation("DriverPreferredVehicle")
  trips      Trip[]

  @@unique([companyId, plate])
  @@map("veiculos")
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// -----------------------------------------------------------------------------
// Motorista: dados pessoais e de pagamento; pertence a uma empresa.
// -----------------------------------------------------------------------------
model Driver {
  id                  String        @id @default(cuid())
  name                String
  cpf                 String
  rg                  String?
  cnh                 String?
  phone               String?
  email               String?
  commissionPct       Decimal?      @map("commission_pct") @db.Decimal(5, 2)
  paymentMethod      String?       @map("payment_method")
  pixKey              String?       @map("pix_key")
  bankName            String?       @map("bank_name")
  bankAgency          String?       @map("bank_agency")
  bankAccount         String?       @map("bank_account")
  status              DriverStatus  @default(ACTIVE)
  preferredVehicleId  String?       @map("preferred_vehicle_id")
  photoUrl            String?       @map("photo_url") // Supabase Storage
  companyId           String        @map("company_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  preferredVehicle   Vehicle?      @relation("DriverPreferredVehicle", fields: [preferredVehicleId], references: [id], onDelete: SetNull)
  trips              Trip[]

  @@map("motoristas")
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

// -----------------------------------------------------------------------------
// Viagem: veículo, motorista, cliente, origem/destino, datas, valor frete, km.
// Código único por viagem; status: Aguardando, Em Andamento, Concluída, Cancelada.
// -----------------------------------------------------------------------------
model Trip {
  id           String      @id @default(cuid())
  code         String      @unique // código único (ex: VG-2026-0001)
  vehicleId    String      @map("vehicle_id")
  driverId     String      @map("driver_id")
  companyId    String      @map("company_id")
  clientName   String?     @map("client_name")
  origin       String?
  destination  String?
  startDate    DateTime    @map("start_date")
  endDate      DateTime?   @map("end_date")
  freightValue Decimal?   @map("freight_value") @db.Decimal(12, 2)
  initialKm    Int?        @map("initial_km")
  finalKm      Int?        @map("final_km") // km final ao concluir viagem
  loadType     String?     @map("load_type") // tipo de carga
  notes        String?     @db.Text
  status       TripStatus  @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle    Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver     Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  expenses   Expense[]
  advances   Advance[]
  settlement Settlement?

  @@map("viagens")
}

enum TripStatus {
  PENDING     // Aguardando
  IN_PROGRESS // Em Andamento
  COMPLETED   // Concluída
  CANCELLED   // Cancelada
}

// -----------------------------------------------------------------------------
// Despesa: lançamento por viagem; categoria, valor, comprovante (Supabase Storage).
// Campos específicos: combustível (litros, preço/litro, posto); pedágio (praça).
// -----------------------------------------------------------------------------
model Expense {
  id             String    @id @default(cuid())
  tripId         String    @map("trip_id")
  categoryId     String    @map("category_id")
  date           DateTime  @db.Date
  amount         Decimal   @db.Decimal(12, 2)
  description    String?   @db.Text
  location       String?
  receiptUrl     String?   @map("receipt_url") // Supabase Storage
  liters         Decimal?  @map("liters") @db.Decimal(10, 2) // combustível
  pricePerLiter  Decimal?  @map("price_per_liter") @db.Decimal(10, 2)
  gasStation     String?   @map("gas_station")
  tollPlaza      String?   @map("toll_plaza") // pedágio
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  trip     Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy User?          @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("despesas")
}

// -----------------------------------------------------------------------------
// Adiantamento (vale): valor, data, método, descrição; múltiplos por viagem.
// -----------------------------------------------------------------------------
model Advance {
  id          String       @id @default(cuid())
  tripId      String       @map("trip_id")
  amount      Decimal      @db.Decimal(12, 2)
  date        DateTime     @db.Date
  method      AdvanceMethod
  description String?      @db.Text
  receiptUrl  String?      @map("receipt_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("adiantamentos")
}

enum AdvanceMethod {
  CASH      // Dinheiro
  PIX       // PIX
  TRANSFER  // Transferência

  @@map("AdvanceMethod")
}

// -----------------------------------------------------------------------------
// Acerto (Settlement): resultado da finalização da viagem; cálculo automático.
// -----------------------------------------------------------------------------
model Settlement {
  id                    String    @id @default(cuid())
  tripId                String    @unique @map("trip_id")
  totalExpenses         Decimal   @map("total_expenses") @db.Decimal(12, 2) @default(0)
  grossProfit          Decimal   @map("gross_profit") @db.Decimal(12, 2) @default(0)
  driverCommissionPct   Decimal   @map("driver_commission_pct") @db.Decimal(5, 2)
  driverCommissionAmt  Decimal   @map("driver_commission_amount") @db.Decimal(12, 2) @default(0)
  totalAdvances        Decimal   @map("total_advances") @db.Decimal(12, 2) @default(0)
  amountToPayDriver    Decimal   @map("amount_to_pay_driver") @db.Decimal(12, 2) @default(0)
  ownerResult          Decimal   @map("owner_result") @db.Decimal(12, 2) @default(0)
  finalKm              Int?      @map("final_km")
  paid                 Boolean   @default(false)
  paidAt               DateTime? @map("paid_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("acertos")
}
